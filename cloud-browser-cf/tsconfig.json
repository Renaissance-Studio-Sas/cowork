{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": [],
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["src", "worker-configuration.d.ts"],
  "exclude": ["container", "node_modules"]
}
