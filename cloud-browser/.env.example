# R2 (Cloudflare S3-compatible) — required unless SKIP_R2=true
R2_BUCKET=browser-profiles-marco
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Optional — defaults shown
# CHROME_IMAGE=cloud-browser/chromium:latest
# IDLE_TIMEOUT_MS=1800000
# PROFILE_CACHE_DIR=~/.cloud-browser/profiles
# DOCKER_HOST=  # uses default Docker socket if unset

# For local iteration without R2 set up yet
# SKIP_R2=true
