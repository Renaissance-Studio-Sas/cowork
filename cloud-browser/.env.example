# cloud-browser is now a thin MCP daemon — the Chrome container itself runs
# in Cloudflare via the cloud-browser infra worker (monorepo/infra/workers/
# cloud-browser), reached through the gateway at /api/browser/*. The daemon
# authenticates with the gateway via the session cookie written by
# `rw auth login`.

# Optional overrides — defaults shown
# RW_GATEWAY=https://app.rowads.studio
# RW_CREDS_FILE=~/.rw/credentials.json

# Local idle reaper — releases the in-MCP handle (and tells the remote to
# destroy its container) after this much inactivity. The remote has its own
# 15-min idle timeout; whichever fires first wins.
# IDLE_TIMEOUT_MS=1800000

# Local HTTP MCP transport. The server runs as a shared daemon; clients
# (cowork agents, Claude Desktop, …) talk to it over Streamable HTTP at
# this address. Loopback-only — never expose off-host.
# CLOUD_BROWSER_HTTP_HOST=127.0.0.1
# CLOUD_BROWSER_HTTP_PORT=7400
# CLOUD_BROWSER_PID_FILE=~/.cloud-browser/server.pid
