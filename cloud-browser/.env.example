# Persistence backend is chosen by env presence:
#   - R2_BUCKET set (and SKIP_R2 != "true")  →  R2  (cloud-shared, scales)
#   - otherwise                              →  local folder under LOCAL_STORE_DIR
#
# Default with this file empty / unset = local folder backend. Profile baselines
# are stored on disk as ~/.cloud-browser/store/<profile>/ (browsable). Only login
# state is kept (cookies, Local Storage, IndexedDB, Preferences, …); throwaway
# caches are filtered out on save.

# R2 (Cloudflare S3-compatible) — leave unset to use the local-folder backend
# R2_BUCKET=browser-profiles-marco
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# Force local even if R2 vars are set (e.g. for offline iteration)
# SKIP_R2=true

# Optional — defaults shown
# CHROME_IMAGE=cloud-browser/chromium:latest
# IDLE_TIMEOUT_MS=1800000
# PROFILE_CACHE_DIR=~/.cloud-browser/profiles   # ephemeral per-session userDataDirs
# LOCAL_STORE_DIR=~/.cloud-browser/store        # persistent baselines (local backend)
# DOCKER_HOST=  # uses default Docker socket if unset

# Local HTTP MCP transport. The server runs as a shared daemon; clients (cowork
# agents, Claude Desktop, …) talk to it over Streamable HTTP at this address.
# Loopback-only — never expose off-host.
# CLOUD_BROWSER_HTTP_HOST=127.0.0.1
# CLOUD_BROWSER_HTTP_PORT=7400
# CLOUD_BROWSER_PID_FILE=~/.cloud-browser/server.pid
