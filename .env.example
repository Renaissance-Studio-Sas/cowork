# Browser automation backend for agent sessions.
#   chrome-mcp     → legacy Claude-in-Chrome bridge (default)
#   control-plane  → steelyard (Docker control plane; Playwright over CDP, reusable profiles)
BROWSER_BACKEND=control-plane

# steelyard REST API. In Docker Compose mode the API + UI are both on :4000.
BROWSER_CONTROL_PLANE_URL=http://localhost:4000

# steelyard management UI (server-side default for links).
BROWSER_UI_URL=http://localhost:4000

# Same management UI, exposed to the browser for the sidebar "Browser ↗" button.
NEXT_PUBLIC_BROWSER_UI_URL=http://localhost:4000

# Optional: where cowork keeps its managed steelyard checkout (default ~/.cowork/steelyard)
# STEELYARD_DIR=
# Optional: override the steelyard git remote used for cloning.
# STEELYARD_REPO_URL=https://github.com/Renaissance-Studio-Sas/Steelyard.git
